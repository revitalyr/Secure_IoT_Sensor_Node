  OBJECT_DIR = CMakeFiles/app.elf.dir
  POST_BUILD = cd /mnt/d/work/Projects/Secure_IoT_Sensor_Node/build-firmware && arm-none-eabi-objcopy -O binary $< /mnt/d/work/Projects/Secure_IoT_Sensor_Node/build-firmware/app.bin && cd /mnt/d/work/Projects/Secure_IoT_Sensor_Node/build-firmware && arm-none-eabi-size $<
  PRE_LINK = :
  TARGET_COMPILE_PDB = CMakeFiles/app.elf.dir/
  TARGET_FILE = app.elf
  TARGET_PDB = app.elf.pdb


